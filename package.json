{
  "name": "chromoscientia-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run copy-assets && next build",
    "start": "next start",
    "lint": "next lint",
    "copy-assets": "node scripts/copy-assets.js",
    "postinstall": "npm run build --prefix packages/shared/game-core && npm run build --prefix packages/shared/shared && npm run copy-assets"
  },
  "dependencies": {
    "@chromoscientia/game-core": "file:./packages/shared/game-core",
    "@chromoscientia/shared": "file:./packages/shared/shared",
    "@lottiefiles/dotlottie-web": "^0.14.1",
    "firebase": "^10.7.0",
    "next": "^16.1.6",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
